@{
    ViewData["Title"] = "Customer Service";
}

<section class="cs-section">
    <div class="cs-inner"> 
    <div class="cs-card">

        <div class="cs-left">
            <img src="/images/training2.jpg" alt="Gym trainer" />
            <div class="cs-contact-bar">
                <div class="cs-contact-item">
                    <div class="cs-contact-icon">
                        <img src="/images/tel.png" alt="Phone" />
                    </div>
                    <div>
                        <div class="cs-contact-label">Phone Number</div>
                        <div class="cs-contact-value">+(46) 8 410 521 00</div>
                    </div>
                </div>
                <div class="cs-contact-item">
                    <div class="cs-contact-icon">
                        <img src="/images/mail.png" alt="Email" />
                    </div>
                    <div>
                        <div class="cs-contact-label">Email Address</div>
                        <div class="cs-contact-value">info@corefitness.se</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="cs-right">
            <h2>Contact Us Today</h2>
            <p class="cs-subtitle">Ready to begin your fitness journey? Contact GymPro today and let our expert trainers guide you with the right program and support.</p>

            <div class="cs-form">
                <div class="cs-row">
                    <div class="cs-field">
                        <label>First Name <span>*</span></label>
                        <input type="text" placeholder="Enter First Name" />
                    </div>
                    <div class="cs-field">
                        <label>Last Name <span>*</span></label>
                        <input type="text" placeholder="Enter Last Name" />
                    </div>
                </div>
                <div class="cs-row">
                    <div class="cs-field">
                        <label>Email Address <span>*</span></label>
                        <input type="email" placeholder="Enter Email Address" />
                    </div>
                    <div class="cs-field">
                        <label>Phone Number</label>
                        <input type="tel" placeholder="Enter Phone Number" />
                    </div>
                </div>
                <div class="cs-field">
                    <label>Message <span>*</span></label>
                    <textarea placeholder="Message..."></textarea>
                </div>
                <button class="cs-submit-btn">
                    Submit Message <span>›</span>
                </button>
            </div>
        </div>

    </div>

    </div>
</section>
